# Stripe Configuration
# Get these from your Stripe Dashboard (https://dashboard.stripe.com/apikeys)

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Secret Key (starts with sk_test_ or sk_live_)
# WARNING: Keep this secret! Never commit this to version control
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# AI provider API keys used by backend routes
MOLMIM_API_KEY=your_molmim_api_key_here
OPENFOLD_API_KEY=your_openfold_api_key_here

# API server port (used by frontend API URL builder)
VITE_API_PORT=3000

# Public/app URLs used by frontend links
VITE_PUBLIC_SITE_URL=https://www.outwize.com
VITE_APP_SITE_URL=https://app.outwize.com
VITE_CONTACT_URL=https://www.outwize.com/contact/
VITE_INSIGHTS_BASE_URL=https://www.outwize.com/insights/
VITE_BLOG_URL=https://www.outwize.com/blog
VITE_LICENSE_URL=https://www.outwize.com/license

# Download links used by services page
VITE_DOWNLOAD_MACROCYCLES_1M=https://www.outwize.com/wp-content/uploads/2025/02/Macrocycles-Final-1M-Compounds.zip
VITE_DOWNLOAD_MACROCYCLES_10K=https://www.outwize.com/wp-content/uploads/2025/01/Macrocycles-Final-10k-Compounds.zip

# Redirect allowlist seed (comma-separated hostnames)
# Used by backend approval-ready redirect feature
APPROVED_REDIRECT_ORIGINS=localhost,127.0.0.1

# Backend URL settings
BASE_URL=https://app.outwize.com
PUBLIC_SITE_URL=https://www.outwize.com
APP_SIGNIN_URL=https://app.outwize.com/auth/sign-in
