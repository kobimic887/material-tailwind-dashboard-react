# RabbitMQ Configuration
# Copy these environment variables to your .env file and update with your RabbitMQ credentials

# RabbitMQ Connection URL (CloudAMQP or local RabbitMQ)
# For CloudAMQP: amqps://username:password@host/vhost
# For local: amqp://localhost:5672
RABBITMQ_URL=amqps://your_user:your_password@your-host/your-vhost

# RabbitMQ Authentication (if using custom URL format)
RABBITMQ_USERNAME=your_user
RABBITMQ_PASSWORD=your_password
RABBITMQ_VHOST=your_vhost

# Queue and Exchange Configuration
ADMET_QUEUE_NAME=admet_processing_queue
ADMET_EXCHANGE_NAME=admet_exchange
ADMET_ROUTING_KEY=admet.process

# Optional: Email notifications for ADMET processing
ADMET_NOTIFICATION_EMAIL=admin@example.com

# Base URL for callbacks (used by ADMET processing service to send results back)
BASE_URL=https://app.outwize.com
